{
  "name": "ai-fit",
  "version": "0.1.0",
  "description": "Your AI-to-app fitting service",
  "main": "src/index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "test": "jest --passWithNoTests",
    "test:components": "jest --config jest.components.config.js",
    "typecheck": "tsc --noEmit",
    "storybook": "sb-rn-get-stories && expo start",
    "storybook:build": "sb-rn-get-stories && expo export:web"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/workers/"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~54.0.0",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "native-base": "^3.4.28",
    "nativewind": "^2.0.11",
    "phosphor-react-native": "^2.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.52.0",
    "react-native": "0.74.0",
    "react-native-safe-area-context": "4.10.0",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "prettier": "^3.3.0",
    "tailwindcss": "3.3.2",
    "typescript": "~5.5.0"
  },
  "private": true,
  "overrides": {
    "tar": ">=7.5.19",
    "shell-quote": ">=1.8.4"
  }
}
